datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Deck {
  id        String   @id @default(cuid())
  title     String
  style     String
  palette   String
  deckDNA   String
  createdAt DateTime @default(now())
  cards     Card[]
}

model Card {
  id        String   @id @default(cuid())
  deckId    String
  title     String
  prompt    String
  imageUrl  String?
  deck      Deck     @relation(fields: [deckId], references: [id])
  createdAt DateTime @default(now())
}
